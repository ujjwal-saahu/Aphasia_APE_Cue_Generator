*.png
*.jpg
*.jpeg

# =========================
# Keep important exports
# =========================
!data/final/*.csv
!data/final/*.json

# =========================
# Keep notebooks and source code
# =========================
!notebooks/**
!src/**
!README.md
!.gitignore